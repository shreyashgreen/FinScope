# FinScope Environment Variables Example
# Copy this file to .env and fill in your values
# This file should NOT be committed to Git

# Optional: NewsAPI Key (not required - app uses yfinance exclusively)
# Get free key at: https://newsapi.org/register (100 requests/day free)
# NEWS_API_KEY=your_newsapi_key_here

# Note: As of v2.0, FinScope uses yfinance exclusively for news
# So NEWS_API_KEY is not required and will be ignored if present
